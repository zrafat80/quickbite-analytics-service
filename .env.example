# ── HTTP ─────────────────────────────────────────────────────────────────────
PORT=5000
ENVIRONMENT=development

# ── Mongo ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=analytics

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_ORDER_EVENTS_EXCHANGE=order.events
RABBITMQ_ORDER_EVENTS_QUEUE=analytics-service.order-events
RABBITMQ_ORDER_EVENTS_BINDINGS=order.#,payment.#
RABBITMQ_ORDER_EVENTS_DLX=order.events.dlx
RABBITMQ_ORDER_EVENTS_DLQ=analytics-service.order-events.dlq
RABBITMQ_CORE_EVENTS_EXCHANGE=core.events
RABBITMQ_CORE_EVENTS_QUEUE=analytics-service.core-events
RABBITMQ_CORE_EVENTS_BINDINGS=rbac.#
RABBITMQ_CORE_EVENTS_DLX=core.events.dlx
RABBITMQ_CORE_EVENTS_DLQ=analytics-service.core-events.dlq
RABBITMQ_PREFETCH=32

# ── Auth ─────────────────────────────────────────────────────────────────────
# MUST match core-service/order-service so issued tokens verify here.
ACCESS_SECRET=devsecret_replace_me

# ── Core-service client (RBAC lookup) ───────────────────────────────────────
CORE_SERVICE_BASE_URL=http://localhost:4000
CORE_INTERNAL_API_KEY=devinternal_replace_me
RBAC_CACHE_TTL_SEC=300

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
