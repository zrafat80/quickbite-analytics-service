            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/analytics/restaurants/42/failures?from=2026-05-01&to=2026-05-22",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "analytics", "restaurants", "42", "failures"],
                  "query": [
                    { "key": "from", "value": "2026-05-01" },
                    { "key": "to", "value": "2026-05-22" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"date\": \"2026-05-21\",\n      \"ordersCount\": 10,\n      \"rejectedCount\": 1,\n      \"failureRate\": 0.1\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "GET /analytics/restaurants/{restaurantId}/delivery-avg",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analytics/restaurants/{{restaurantId}}/delivery-avg?from={{from}}&to={{to}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analytics", "restaurants", "{{restaurantId}}", "delivery-avg"],
              "query": [
                { "key": "from", "value": "{{from}}", "description": "YYYY-MM-DD UTC, required." },
                { "key": "to", "value": "{{to}}", "description": "YYYY-MM-DD UTC, required, >= from." }
              ],
              "variable": [
                { "key": "restaurantId", "value": "{{restaurantId}}", "description": "int64 > 0" }
              ]
            },
            "description": "Per-day average delivery time in milliseconds (`delivery_ms_sum / delivery_ms_count`). `deliveriesCounted` distinguishes \"no deliveries\" from \"deliveries with 0 average\"."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/analytics/restaurants/42/delivery-avg?from=2026-05-01&to=2026-05-22",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "analytics", "restaurants", "42", "delivery-avg"],
                  "query": [
                    { "key": "from", "value": "2026-05-01" },
                    { "key": "to", "value": "2026-05-22" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"date\": \"2026-05-21\",\n      \"deliveriesCounted\": 8,\n      \"avgDeliveryMs\": 1820000\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "GET /analytics/restaurants/top",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analytics/restaurants/top?from={{from}}&to={{to}}&limit={{topLimit}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "analytics", "restaurants", "top"],
              "query": [
                { "key": "from", "value": "{{from}}", "description": "YYYY-MM-DD UTC, required." },
                { "key": "to", "value": "{{to}}", "description": "YYYY-MM-DD UTC, required, >= from." },
                { "key": "limit", "value": "{{topLimit}}", "description": "1..100, optional; service-default when omitted." }
              ]
            },
            "description": "Top restaurants by revenue over `[from, to]`. Backed by a Mongo `$group + $sort + $limit` aggregation pipeline."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/analytics/restaurants/top?from=2026-05-01&to=2026-05-22&limit=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "analytics", "restaurants", "top"],
                  "query": [
                    { "key": "from", "value": "2026-05-01" },
                    { "key": "to", "value": "2026-05-22" },
                    { "key": "limit", "value": "10" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"restaurantId\": 42,\n      \"ordersCount\": 120,\n      \"revenueMinor\": 360000,\n      \"currency\": \"EGP\"\n    }\n  ]\n}"
            }
          ]
        }
      ]
    },
